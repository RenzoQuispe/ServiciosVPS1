# Puerto del servicio
PORT=3000

# base de datos supabase
DB_HOST=
DB_PORT=6543
DB_NAME=postgres
DB_USER=
DB_PASSWORD=
DB_SSL=true

# Proveedor de códigos de barras (UPCitemDB)
LLAMADA_BARRAS_BASE_URL=https://api.upcitemdb.com
LLAMADA_BARRAS_LOOKUP_PATH=/prod/trial/lookup
LLAMADA_BARRAS_API_KEY=
LLAMADA_BARRAS_APIKEY_HEADER=key
HTTP_TIMEOUT_MS=8000

# Google Custom Search (fallback de imágenes)
GOOGLE_API_KEY=
GOOGLE_CSE_ID=
GOOGLE_TIMEOUT_MS=8000
GOOGLE_QUEUE_CONCURRENCY=1
GOOGLE_QUEUE_MIN_INTERVAL_MS=350
GOOGLE_QUEUE_MAX=2000
GOOGLE_IMAGE_NUM=1

# Cache: días para considerar un producto en DB como fresco
CACHE_TTL_DAYS=90
IMAGE_DOWNLOAD_TIMEOUT_MS=10000
