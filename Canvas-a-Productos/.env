# Puerto del servicio
PORT=3000

# OpenAI (requerido para extracción)
OPENAI_API_KEY=

# Modelos OpenAI por paso (cada uno opcional; si no está, se usa el anterior)
# PAGE = detección por página/screenshot
# CROP = refinado por crop (two-pass)
# ENRICH = enriquecimiento de nombres/descripciones
OPENAI_MODEL_PAGE=gpt-4o
OPENAI_MODEL_CROP=gpt-4o-mini
OPENAI_MODEL_ENRICH=gpt-4o-mini

# Activar enriquecimiento por defecto al hacer POST /extract (p. ej. con docker compose up)
ENABLE_ENRICH=0
# Mejorar descripciones: usa las del canvas (two_pass) o genera una corta tipo e-commerce con modelo barato (1 llamada batch)
ENABLE_IMPROVE_DESCRIPTIONS=1
OPENAI_MODEL_DESCRIPTIONS=gpt-4o-mini
# ENRICH_BATCH_SIZE=6
# ENRICH_MAX_CALLS=50
# ENRICH_DEDUPE=0

# Mejora cada crop con IA (Gemini) en el VPS — mismo flujo que "Mejorar imagen con IA" del frontend.
# Para desactivar: comenta la línea improve_crop_via_backend(crop_path) en script.py
NANO_BANANA_API_KEY=